rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---
    function isSignedIn() {
      return request.auth != null && request.auth.token != null && request.auth.token.email != null;
    }

    function isOwner(res) {
      return isSignedIn() && 
             res != null && 
             res.data != null && 
             res.data.get('mobile', '') + '@kingwallet.com' == request.auth.token.email;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "7477661867@kingwallet.com" ||
        request.auth.token.email == "9172091478@kingwallet.com"
      );
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isSignedIn() && (
        resource == null ||
        isOwner(resource) ||
        isAdmin()
      );
      allow list: if isSignedIn() && (
        isOwner(resource) ||
        isAdmin()
      );
      allow create: if false; // Handled entirely via secure backend API
      allow update: if isSignedIn() && (
        resource == null ||
        isOwner(resource) ||
        isAdmin()
      );
      allow delete: if false;
    }

    // --- Transactions Collection ---
    match /transactions/{txnId} {
      allow get, list: if isSignedIn() && (
        isOwner(resource) ||
        isAdmin()
      );
      allow create: if isSignedIn(); // Users can request deposits/payouts
      allow update, delete: if isAdmin(); // Only admins can update statuses manually
    }

    // --- Chats Collection ---
    match /chats/{chatId} {
      allow get, list: if isSignedIn() && (
        isOwner(resource) ||
        isAdmin()
      );
      allow create: if isSignedIn(); // Handled via API or directly if signed in
      allow update, delete: if isAdmin();
    }

    // --- Gift Codes Collection ---
    match /giftCodes/{codeId} {
      allow read: if isSignedIn(); // Anyone can check or look up codes
      allow write: if isAdmin();  // Only admins can create codes
    }

    // --- Lifafas Collection ---
    match /lifafas/{lifafaId} {
      allow read: if isSignedIn(); 
      allow write: if isSignedIn(); // Allow redeeming or creating lifafa
    }

    // --- API Logs Collection ---
    match /apiLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
